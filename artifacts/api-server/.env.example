# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/eduplatform

# ─── Authentication (Clerk) ───────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_...

# ─── AI / OpenAI ─────────────────────────────────────────────────────────────
# Used for Whisper transcription (STT) and essay auto-grading
# On Replit: provided automatically via AI Integrations
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Object Storage ───────────────────────────────────────────────────────────
# Directory for private file uploads (audio recordings, etc.)
PRIVATE_OBJECT_DIR=/tmp/objects/private
# Comma-separated paths that are publicly accessible
PUBLIC_OBJECT_SEARCH_PATHS=/tmp/objects/public

# ─── Google Classroom Integration (optional) ──────────────────────────────────
GOOGLE_CLASSROOM_CLIENT_ID=

# ─── Moodle Integration (optional) ───────────────────────────────────────────
MOODLE_URL=https://your-moodle-site.com
MOODLE_TOKEN=
