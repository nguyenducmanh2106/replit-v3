{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development pnpm run build && pnpm run start",
    "dev:debug": "cross-env NODE_ENV=development pnpm run build && pnpm run start:debug",
    "build": "node ./build.mjs",
    "start": "node --env-file-if-exists=../../.env --env-file-if-exists=.env --enable-source-maps ./dist/index.mjs",
    "start:debug": "node --inspect=0.0.0.0:8080 --env-file-if-exists=../../.env --env-file-if-exists=.env --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@types/nodemailer": "^8.0.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "@workspace/integrations-google-ai-server": "workspace:*",
    "@google/genai": "^1.3.0",
    "better-auth": "^1.6.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "google-auth-library": "^10.6.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "openai": "^6.34.0",
    "pino": "^9",
    "pino-http": "^10",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
