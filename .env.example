# ─────────────────────────────────────────────────────────────────────────────
# Root .env.example — EduPlatform monorepo
#
# Copy this file to .env and fill in the values.
# Each artifact also has its own .env.example with more specific guidance.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (shared by API server & migrations) ────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/eduplatform

# ─── Authentication (Clerk) ───────────────────────────────────────────────────
# Backend secret key — keep private, never expose to frontend
CLERK_SECRET_KEY=sk_test_...
# Frontend publishable key — safe to expose to browsers
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# Optional Clerk proxy URL for Replit-hosted deployments
VITE_CLERK_PROXY_URL=

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# ─── AI / OpenAI ──────────────────────────────────────────────────────────────
# Used for Whisper STT transcription and AI essay grading
# On Replit: provided automatically via the AI Integrations panel
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Object Storage ───────────────────────────────────────────────────────────
PRIVATE_OBJECT_DIR=/tmp/objects/private
PUBLIC_OBJECT_SEARCH_PATHS=/tmp/objects/public

# ─── Mobile App ───────────────────────────────────────────────────────────────
# Must be prefixed with EXPO_PUBLIC_ to be accessible in Expo/React Native
EXPO_PUBLIC_DOMAIN=https://your-api-domain.replit.app

# ─── Optional Integrations ────────────────────────────────────────────────────
GOOGLE_CLASSROOM_CLIENT_ID=
MOODLE_URL=https://your-moodle-site.com
MOODLE_TOKEN=
